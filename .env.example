2# ============================================================
#  TRADE BOT — Environment Variables
# ============================================================
# Kopyalayıp .env olarak kaydedin ve değerleri girin.
# NOT: Borsalar public API kullanır, API key gerekmez.

# --- Telegram (ZORUNLU) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CryptoPanic (Opsiyonel) ---
# Boş bırakılırsa haber servisi health check'te "ayarsız" görünür.
CRYPTOPANIC_API_KEY=

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# --- Genel ---
LOG_LEVEL=INFO

# Sembol modu:
#   auto  -> Bybit'teki tüm USDT perp semboller otomatik çekilir
#   liste -> BTC/USDT,ETH/USDT,SOL/USDT
SYMBOLS=auto
